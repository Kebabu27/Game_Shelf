# Clé API RAWG — obtenez-la gratuitement sur https://rawg.io/apidocs
VITE_RAWG_KEY=your_rawg_api_key_here

# Base de l'API (ne pas modifier sauf besoin)
VITE_RAWG_BASE_URL=https://api.rawg.io/api

# Supabase (authentification + synchro de la bibliothèque)
# Project Settings -> API sur supabase.com. Laisser vide désactive l'auth.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key
